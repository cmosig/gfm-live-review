    </div>
    <div class="head-actions">
      <a class="repo-link" href="https://github.com/cmosig/gfm-live-review"
         rel="noopener" title="Source, pipeline and every extracted card on GitHub">
        <svg viewBox="0 0 16 16" width="15" height="15" aria-hidden="true" focusable="false">
